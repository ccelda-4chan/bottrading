# Bitget API Credentials (Demo Account)
# Get these from Bitget personal center -> API Key Management (Demo Mode)
API_KEY=your_api_key
API_SECRET=your_api_secret
API_PASSPHRASE=your_api_passphrase

# Symbols to trade
# The user mentioned SBTCUSDT/SETHSUSDT/SXRPSUSDT
# Bitget documentation says SBTCSUSDT/SETHSUSDT/SXRPSUSDT
SYMBOLS=SBTCSUSDT,SETHSUSDT,SXRPSUSDT

# Risk Management
MAX_RISK_PER_TRADE_PERCENT=1.0
DEFAULT_LEVERAGE=10
